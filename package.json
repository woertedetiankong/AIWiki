{
  "name": "@superwoererte/aiwiki",
  "version": "0.1.1",
  "description": "Local-first AI coding memory and context engineering CLI.",
  "license": "MIT",
  "keywords": [
    "ai",
    "coding-agent",
    "context",
    "knowledge-base",
    "local-first",
    "markdown",
    "memory",
    "sqlite"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woertedetiankong/AIWiki.git"
  },
  "bugs": {
    "url": "https://github.com/woertedetiankong/AIWiki/issues"
  },
  "homepage": "https://github.com/woertedetiankong/AIWiki#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "aiwiki": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dev:aiwiki": "tsx src/cli.ts",
    "eval:large-repos": "npm run build && node dist/cli.js eval large-repos",
    "eval:usability": "npm run build && node dist/cli.js eval usability",
    "pack:dry-run": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check",
    "release:check": "npm run typecheck && npm run test && npm run build && npm run pack:dry-run",
    "test": "vitest run --testTimeout=15000",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.2",
    "gray-matter": "^4.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": "20.x || 22.x || 24.x"
  }
}
